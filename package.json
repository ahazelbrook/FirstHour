{
  "name": "firsthour",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "npm run build && wrangler dev",
    "icons": "node scripts/generate-icons.mjs",
    "voice": "node --experimental-strip-types scripts/generate-voice.ts",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/sono": "^5.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "framer-motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
